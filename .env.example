# Instance MongoDB de développement (replica set à un nœud, port 27018).
# Démarrage : npm run mongo:start
# Le paramètre replicaSet est indispensable : sans lui le driver traite le
# nœud comme un standalone et refuse les transactions.
MONGODB_URI="mongodb://127.0.0.1:27018/lecteur-csv?replicaSet=rs-lecteur-csv"

# En production, remplacer par l'URI Atlas (les clusters Atlas sont déjà des
# replica sets, les transactions y fonctionnent sans configuration) :
# MONGODB_URI="mongodb+srv://<utilisateur>:<motdepasse>@<cluster>.mongodb.net/lecteur-csv?retryWrites=true&w=majority"
